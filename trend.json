{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Migration dropped during COVID-19, then rebounded sharply",
    "subtitle": "Net overseas migration, financial years 2004–05 to 2024–25",
    "subtitleFontStyle": "italic",
    "subtitleFontSize": 12,
    "anchor": "start"
  },
  "width": 720,
  "height": 350,
  "data": {
    "url": "migration_trend_australia.csv"
  },
  "mark": {
    "type": "line",
    "point": true,
    "strokeWidth": 3
  },
  "encoding": {
    "x": {
      "field": "financial_year",
      "type": "ordinal",
      "title": "Financial year",
      "axis": {
        "labelAngle": -45
      }
    },
    "y": {
      "field": "net_overseas_migration_total",
      "type": "quantitative",
      "title": "Net overseas migration",
      "axis": {
        "format": ",.0f"
      }
    },
    "tooltip": [
      {
        "field": "financial_year",
        "title": "Financial year"
      },
      {
        "field": "net_overseas_migration_total",
        "title": "Net overseas migration",
        "format": ","
      },
      {
        "field": "net_overseas_migration_overseas_born",
        "title": "Overseas-born",
        "format": ","
      },
      {
        "field": "net_overseas_migration_australian_born",
        "title": "Australian-born",
        "format": ","
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "background": "white"
  }
}