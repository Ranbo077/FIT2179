{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Where are overseas-born Australians concentrated?",
    "subtitle": "Share of population born overseas by state and territory, 2021",
    "subtitleFontStyle": "italic",
    "subtitleFontSize": 12,
    "anchor": "start"
  },
  "width": 720,
  "height": 520,
  "layer": [
    {
      "data": { "graticule": { "step": [15, 15] } },
      "mark": {
        "type": "geoshape",
        "stroke": "#dbe3ea",
        "strokeWidth": 0.6,
        "fill": null,
        "opacity": 0.7,
        "clip": true
      }
    },
    {
      "data": {
        "url": "australia_states.json",
        "format": { "type": "topojson", "feature": "australia_states.json" }
      },
      "transform": [
        {
          "lookup": "properties.name",
          "from": {
            "data": {
              "url": "state_diversity_summary.csv"
            },
            "key": "state",
            "fields": [
              "overseas_born_population_2021",
              "total_population_2021",
              "overseas_born_percent_2021",
              "non_english_language_count_2021",
              "non_english_language_percent_2021"
            ]
          }
        }
      ],
      "projection": {
        "type": "mercator",
        "center": [133, -28],
        "scale": 900
      },
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 1
      },
      "encoding": {
        "color": {
          "field": "overseas_born_percent_2021",
          "type": "quantitative",
          "title": "Overseas-born population (%)",
          "scale": {
            "scheme": "blues",
            "domain": [0, 45],
            "naColor": "#eeeeee"
          }
        },
          "tooltip": [
            { "field": "properties.name", "title": "State/Territory" },
            { "field": "overseas_born_percent_2021", "title": "Overseas-born (%)", "format": ".1f" },
            { "field": "overseas_born_population_2021", "title": "Overseas-born population", "format": "," },
            { "field": "total_population_2021", "title": "Total population", "format": "," },
            { "field": "non_english_language_percent_2021", "title": "Non-English at home (%)", "format": ".1f" },
            { "field": "non_english_language_count_2021", "title": "Non-English speakers", "format": "," }
          ]
      }
    }
  ],
  "config": {
    "view": { "stroke": null },
    "background": "white",
    "geoshape": { "invalid": null }
  }
}